# ─────────────────────────────────────────────────────────────
# statum — environment configuration
# Copy to .env and fill in the values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Password for the admin panel at /admin.php
ADMIN_PASSWORD=changeme

# Title shown on the public status page tab and header
SITE_NAME=My Status Page

# Email address for alert notifications (reserved — not yet implemented)
ALERT_EMAIL=

# Shared secret for the /api/report webhook endpoint (n8n integration).
# Send it as the X-Webhook-Token header. Leave empty to disable auth.
WEBHOOK_TOKEN=

# Secret token for triggering checks via HTTP at /cron.php.
# Required — endpoint returns 500 if not set.
# Send as: GET /cron.php?token=VALUE  or  X-Cron-Token header.
CRON_TOKEN=

# ── Supabase (optional) ───────────────────────────────────────
# When set, check results are synced to Supabase after each SQLite write.
# Required Supabase table: see README → Supabase section for the SQL schema.

# Your Supabase project URL — found in Project Settings → API
# Example: https://abcdefghijkl.supabase.co
SUPABASE_URL=

# Supabase anon/public key — found in Project Settings → API → Project API keys
# Used only for the DB badge display check (header indicator)
SUPABASE_KEY=

# Supabase database password — found in Project Settings → Database → Database password
# When set together with SUPABASE_URL, ALL data is stored in Supabase (PostgreSQL).
# SQLite is used only as fallback when this is empty.
SUPABASE_DB_PASSWORD=
